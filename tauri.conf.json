{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Push-to-Talk",
  "version": "0.1.0",
  "identifier": "ru.tcsbank.push-to-talk",
  "build": {
    "frontendDist": "./html"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Push-to-Talk",
        "width": 750,
        "height": 650,
        "resizable": true,
        "center": true,
        "visible": true,
        "focus": true,
        "closable": true,
        "minimizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
