{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Push-to-Talk",
  "version": "0.1.0",
  "identifier": "org.moonlightflame.push-to-talk",
  "build": {
    "frontendDist": "./ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Push-to-Talk",
        "width": 750,
        "height": 650,
        "resizable": true,
        "center": true,
        "visible": false,
        "focus": true,
        "closable": true,
        "minimizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline' asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost ws://localhost:5173; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "Push-to-Talk"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
