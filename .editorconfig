# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Rust source files
[*.rs]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 120

# TOML files (Cargo.toml, etc.)
[*.toml]
indent_style = space
indent_size = 2

# YAML files
[*.yml, *.yaml]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Git attributes
[.gitignore, .gitattributes]
indent_style = space
indent_size = 2
